# Ollama endpoint (Cloud Run URL or http://localhost:11434/v1 for local)
OLLAMA_BASE_URL=https://<your-cloud-run-ollama-service>/v1

# API key: "ollama" for local, or a Google ID token for Cloud Run
OLLAMA_API_KEY=ollama

# Which architecture is running: HOGENT | CLOUD_RUN | PWA
ARCHITECTURE=HOGENT

# Optional overrides (defaults shown)
# PORT=5000
# DB_DIR=./instance

# Only used by 1_Server_OnPrem for GCS database backup
# GCS_BUCKET=thesis-measurements-bucket
# GCS_BLOB=measurements_hogent.db
