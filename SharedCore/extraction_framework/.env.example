# Environment variables for Document Extraction Tester

# ============================================
# LLM PROVIDERS CONFIGURATION (JSON Format)
# ============================================
# IMPORTANTE: Il JSON deve essere su una singola riga per compatibilità con .env
# Formato: {"provider_name": {"api_key": "...", "base_url": "...", "models": [...]}}

LLM_PROVIDERS={"openai": {"api_key": "sk-your-openai-api-key-here", "base_url": "https://api.openai.com/v1", "models": ["gpt-4o", "gpt-4o-mini", "gpt-4-turbo"]}, "gemini": {"api_key": "your-gemini-api-key-here", "models": ["gemini-1.5-pro", "gemini-1.5-flash", "gemini-1.0-pro"]}, "azure": {"api_key": "your-azure-key", "base_url": "https://your-resource.openai.azure.com/", "models": ["gpt-4", "gpt-35-turbo"]}, "lmstudio": {"api_key": "not-needed", "base_url": "http://localhost:1234/v1", "models": ["local-model"]}, "ollama": {"api_key": "not-needed", "base_url": "http://localhost:11434/v1", "models": ["llama3", "mistral", "gemma2:9b"]}}

# Esempio minimo (solo OpenAI):
# LLM_PROVIDERS={"openai": {"api_key": "sk-...", "models": ["gpt-4o", "gpt-4o-mini"]}}

# Esempio con Gemini:
# LLM_PROVIDERS={"gemini": {"api_key": "AIza...", "models": ["gemini-1.5-pro", "gemini-1.5-flash"]}}

# Note: 
# - api_key è obbligatoria (tranne per provider locali come LM Studio/Ollama)
# - base_url è opzionale (default: https://api.openai.com/v1 per provider openai-compatible)
# - models è la lista di modelli disponibili per quel provider
